<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dipak Kumar Saha | ECE Portfolio</title>
    <style>
        /* --- CORE STYLES & RESET --- */
        :root {
            --primary-bg: #f4f7f6; /* Very light, professional grey */
            --secondary-bg: #ffffff; /* Pure white for content cards */
            --text-main: #2c3e50; /* Dark blue-grey for main text */
            --text-muted: #7f8c8d; /* Muted grey for descriptions */
            --accent: #3498db; /* Professional blue for links/highlights */
            --accent-hover: #2980b9; /* Darker blue for hover states */
            --border-color: #e0e0e0;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            --transition: all 0.3s ease;
            --font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--primary-bg);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden; /* Prevent horizontal scroll from animations */
        }

        a {
            text-decoration: none;
            color: inherit;
            transition: var(--transition);
        }

        ul {
            list-style: none;
        }

        /* --- UNIFIED LAYOUT & SECTION STYLES --- */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px;
        }

        section {
            padding: 60px 0;
            border-bottom: 1px solid var(--border-color);
        }

        section:last-of-type {
            border-bottom: none;
        }

        /* Smooth reveal animation for sections on scroll */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.6s ease-out, transform 0.6s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- SECTION TITLES (Simple & Unique) --- */
        .section-title {
            font-size: 2.2rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-main);
            margin-bottom: 40px;
            position: relative;
            display: inline-block;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 50px;
            height: 4px;
            background-color: var(--accent);
            border-radius: 2px;
            transition: width 0.5s ease;
        }

        section:hover .section-title::after {
            width: 100%;
        }

        /* --- HERO / HEADER SECTION --- */
        header {
            background-color: var(--secondary-bg);
            padding: 80px 0 40px;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
            position: relative;
        }

        #hero h1 {
            font-size: 3.5rem;
            color: var(--text-main);
            margin-bottom: 10px;
            animation: fadeInDown 1s ease;
        }

        #hero .subtitle {
            font-size: 1.2rem;
            color: var(--accent);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 25px;
            animation: fadeInUp 1s ease 0.2s;
            animation-fill-mode: both;
        }

        #hero .contact-info {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            font-size: 1rem;
            color: var(--text-muted);
            animation: fadeIn 1s ease 0.4s;
            animation-fill-mode: both;
        }

        #hero .contact-info a:hover {
            color: var(--accent);
        }

        /* --- OBJECTIVE SECTION --- */
        #objective .content-card {
            background: var(--secondary-bg);
            padding: 40px;
            border-radius: 8px;
            box-shadow: var(--shadow);
            border-left: 5px solid var(--accent);
        }

        #objective p {
            font-size: 1.1rem;
            color: var(--text-main);
            margin-bottom: 15px;
        }

        #objective p:last-child {
            margin-bottom: 0;
            font-weight: bold;
            color: var(--accent);
        }

        /* --- SKILLS SECTION (Unique Card Grid) --- */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .skill-card {
            background: var(--secondary-bg);
            padding: 25px;
            border-radius: 8px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            border: 1px solid transparent;
            position: relative;
            overflow: hidden;
        }

        .skill-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
        }

        /* Subtle background icon for unique touch */
        .skill-card::after {
            content: '</>'; /* Placeholder icon */
            position: absolute;
            bottom: -20px;
            right: -10px;
            font-size: 5rem;
            color: rgba(52, 152, 219, 0.05); /* Very faint accent color */
            font-family: monospace;
            transform: rotate(-15deg);
        }

        .skill-card h3 {
            font-size: 1.3rem;
            color: var(--accent);
            margin-bottom: 15px;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 8px;
        }

        .skill-card p {
            color: var(--text-main);
            font-size: 1rem;
            font-weight: 500;
        }

        /* --- EDUCATION SECTION (Timeline Style) --- */
        .timeline {
            position: relative;
            padding-left: 30px;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 4px;
            height: 100%;
            background-color: var(--border-color);
            border-radius: 2px;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 40px;
        }

        .timeline-item:last-child {
            margin-bottom: 0;
        }

        /* The timeline 'dot' */
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -35px; /* Aligns with the line */
            top: 5px;
            width: 14px;
            height: 14px;
            background-color: var(--accent);
            border-radius: 50%;
            border: 3px solid var(--secondary-bg);
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
            transition: var(--transition);
        }

        .timeline-item:hover::before {
            background-color: var(--accent-hover);
            transform: scale(1.2);
        }

        .timeline-date {
            font-size: 0.9rem;
            color: var(--accent);
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .timeline-title {
            font-size: 1.4rem;
            color: var(--text-main);
            font-weight: 600;
        }

        .timeline-subtitle {
            font-size: 1rem;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .timeline-detail {
            font-size: 1rem;
            color: var(--text-main);
            background: var(--secondary-bg);
            padding: 10px 15px;
            border-radius: 4px;
            display: inline-block;
            box-shadow: var(--shadow);
        }

        /* --- CERTIFICATIONS SECTION --- */
        #certifications ul {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        #certifications li {
            background: var(--secondary-bg);
            padding: 20px;
            border-radius: 8px;
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            gap: 15px;
            transition: var(--transition);
        }

        #certifications li:hover {
            background-color: #eaf6fd; /* Very faint blue hover */
        }

        /* Unique prefix icon */
        #certifications li::before {
            content: '★';
            color: var(--accent);
            font-size: 1.2rem;
        }

        /* --- PROJECTS SECTION (Detailed Cards) --- */
        .projects-list {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .project-card {
            background: var(--secondary-bg);
            padding: 30px;
            border-radius: 8px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            border-top: 4px solid transparent;
        }

        .project-card:hover {
            border-top-color: var(--accent);
        }

        .project-card h3 {
            font-size: 1.6rem;
            color: var(--text-main);
            margin-bottom: 15px;
        }

        .project-card ul {
            list-style: disc;
            padding-left: 20px;
            color: var(--text-muted);
        }

        .project-card li {
            margin-bottom: 10px;
        }

        /* --- POSITIONS & HOBBIES (Two-Column Layout) --- */
        .flex-grid {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        .flex-item {
            flex: 1;
            min-width: 300px;
            background: var(--secondary-bg);
            padding: 30px;
            border-radius: 8px;
            box-shadow: var(--shadow);
        }

        .flex-item h3 {
            font-size: 1.4rem;
            color: var(--accent);
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .flex-item ul {
            list-style: disc;
            padding-left: 20px;
            color: var(--text-muted);
        }

        .flex-item li {
            margin-bottom: 10px;
        }

        /* --- FOOTER --- */
        footer {
            background-color: var(--text-main);
            color: #ecf0f1;
            padding: 30px 0;
            text-align: center;
            font-size: 0.9rem;
        }

        /* --- ANIMATIONS & RESPONSIVENESS --- */
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }

        @media (max-width: 768px) {
            #hero h1 { font-size: 2.5rem; }
            .section-title { font-size: 1.8rem; }
            .timeline { padding-left: 20px; }
            .timeline-item::before { left: -25px; }
        }
    </style>
</head>
<body>

    <header id="hero">
        <div class="container">
            <h1>Dipak Kumar Saha</h1>
            <p class="subtitle">ECE Student | Electronics & Communications Engineer</p>
            <div class="contact-info">
                <a href="mailto:Dipaksaha8084@gmail.com">Dipaksaha8084@gmail.com</a>
                <a href="tel:+916203466944">+91-6203466944</a>
                <a href="https://github.com/Dipak-80" target="_blank">Github: Dipak-80</a>
            </div>
        </div>
    </header>

    <section id="objective" class="reveal">
