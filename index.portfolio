    <footer>
        <div class="container">
            <p>&copy; 2023 Dipak Kumar Saha. All details captured from source.</p>
        </div>
    </footer>

    <script>
        // Function to check if elements are in viewport and add 'active' class
        function revealSections() {
            const reveals = document.querySelectorAll('.reveal');
            const windowHeight = window.innerHeight;
            const revealPoint = 150; // Triggers animation before element is fully visible

            reveals.forEach(reveal => {
                const revealTop = reveal.getBoundingClientRect().top;

                if (revealTop < windowHeight - revealPoint) {
                    reveal.classList.add('active');
                }
                // Optional: Remove class to re-trigger animation when scrolling up
                // else { reveal.classList.remove('active'); }
            });
        }

        // Run function on load and scroll
        window.addEventListener('scroll', revealSections);
        window.addEventListener('load', revealSections); // Trigger on page load
    </script>
</body>
</html>
