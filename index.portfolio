        </div>
    </section>

    <section id="education" class="reveal">
        <div class="container">
            <h2 class="section-title">Education</h2>
            <div class="timeline">
                
                <div class="timeline-item">
                    <div class="timeline-date">Sep 2023 - June 2026</div>
                    <div class="timeline-title">Haldia Institute Of Technology</div>
                    <div class="timeline-subtitle">Bachelors of Engineering in Electronic and Communication Engineering</div>
                    <div class="timeline-detail">CGPA: 7.68 / 10</div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-date">Aug 2019 - July 2022</div>
                    <div class="timeline-title">Pakur Polytechnic</div>
                    <div class="timeline-subtitle">Diploma in Electrical Engineering</div>
                    <div class="timeline-detail">Score: 78.31%</div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-date">May 2017 (Pass Out)</div>
                    <div class="timeline-title">Matriculation</div>
                    <div class="timeline-subtitle">High School</div>
                    <div class="timeline-detail">Score: 70.6%</div>
                </div>

            </div>
        </div>
    </section>

    <section id="certifications" class="reveal">
        <div class="container">
            <h2 class="section-title">Certifications</h2>
            <ul>
                <li>Machine Learning with Python and Cloud (By Ardent computech pvt. Ltd.)</li>
                <li>Oracle Certified Professional (Cloud and Gen Ai)</li>
